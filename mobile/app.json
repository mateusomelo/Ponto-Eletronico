{
  "expo": {
    "name": "PontoControl",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "A câmera é usada para tirar a selfie obrigatória no registro de ponto.",
        "NSLocationWhenInUseUsageDescription": "A localização é usada para validar o local do registro de ponto.",
        "NSFaceIDUsageDescription": "O Face ID é usado para confirmar sua identidade ao entrar no app."
      }
    },
    "android": {
      "package": "com.pontoeletronico.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "A câmera é usada para tirar a selfie obrigatória no registro de ponto.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "A localização é usada para validar o local do registro de ponto."
        }
      ],
      "expo-sharing",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1e3a5f"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon-preto.png",
          "imageWidth": 260,
          "resizeMode": "contain",
          "backgroundColor": "#f0f4f8"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c6eb9248-90bc-498f-bf3d-28da88800497"
      }
    },
    "owner": "projetos13",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c6eb9248-90bc-498f-bf3d-28da88800497"
    }
  }
}
