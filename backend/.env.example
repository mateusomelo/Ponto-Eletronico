# Copie como .env (desenvolvimento) ou configure no painel do Railway (producao)
# NUNCA commite o .env real no git

NODE_ENV=production
PORT=3000
HTTPS_PORT=3443

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=TROQUE_ESTA_SENHA
DB_NAME=ponto_eletronico

JWT_SECRET=GERE_UM_SEGREDO_ALEATORIO_64_CHARS
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=GERE_OUTRO_SEGREDO_ALEATORIO_64_CHARS
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_ROUNDS=12

CORS_ORIGINS=https://SEU-SITE.netlify.app

UPLOADS_PATH=/data/uploads

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=seuemail@gmail.com
EMAIL_PASS=sua_senha_de_app_gmail
EMAIL_FROM=PontoControl <noreply@suaempresa.com>

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
LOGIN_RATE_LIMIT_MAX=10

# ── Stripe (Planos e Pagamentos) ─────────────────────────────
# Obtenha em: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_COLOQUE_SUA_CHAVE_STRIPE_AQUI

# Webhook: crie em https://dashboard.stripe.com/webhooks
# URL do endpoint: https://SEU-BACKEND.up.railway.app/api/stripe/webhook
# Eventos necessários: checkout.session.completed, invoice.paid, invoice.payment_failed,
#                      customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_COLOQUE_O_SEGREDO_DO_WEBHOOK_AQUI

# Price IDs dos planos (Stripe Dashboard > Products)
STRIPE_PRICE_BASICO=price_COLOQUE_O_PRICE_ID_DO_BASICO
STRIPE_PRICE_PROFISSIONAL=price_COLOQUE_O_PRICE_ID_DO_PROFISSIONAL
STRIPE_PRICE_ENTERPRISE=price_COLOQUE_O_PRICE_ID_DO_ENTERPRISE

# URL pública do frontend (usada nos redirects do Stripe Checkout)
FRONTEND_URL=https://SEU-SITE.netlify.app
